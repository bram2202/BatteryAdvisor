{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApplicationOptions": {
    "HomeAssistant": {
      "Url": "http://homeassistant.local:8123",
      "Token": "your_long_lived_access_token_here",
      "WebSocketResponseTimeoutSeconds": 10
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=app.db"
  }
}